# Claudinite mount (synced contents ignored; only the tracked sync hook signals the mount)
/.claudinite/*
!/.claudinite/mount/
/.claudinite/mount/*
!/.claudinite/mount/sync-claudinite.sh
!/.claudinite/local_packs/
/.claudinite.new/
/.claudinite-hooks.log
/.claudinite-hooks.log.tmp

# Dependencies
node_modules/

# Build output
dist/
.aws-sam/
*.zip

# Local, owner-specific config (never committed)
extension/config.local.json

# Executable-requirements snapshot debugging artifacts (the rendered "actual" written on a golden
# mismatch; regenerated on failure, never committed — the committed goldens beside the cases are the truth)
dev/requirements/shared/.artifacts/

# Logs / coverage / OS cruft
*.log
coverage/
.DS_Store

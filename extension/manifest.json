{
  "manifest_version": 3,
  "name": "TLDR — community notes",
  "version": "0.2.3",
  "description": "Read and post community tl;dr notes attached to any web page.",
  "minimum_chrome_version": "116",
  "permissions": [
    "identity",
    "scripting",
    "sidePanel",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/service-worker.mjs",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "action": {
    "default_title": "Open TLDR notes",
    "default_popup": "src/category-menu.html"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": false
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/link-hover.mjs",
        "src/log.mjs",
        "src/denylist.mjs",
        "src/link-hover-gate.mjs",
        "src/hover-tooltip.mjs",
        "src/categories/registry.mjs",
        "src/categories/tldr/design.mjs",
        "src/categories/spoiler/design.mjs",
        "src/categories/chitchat/design.mjs",
        "vendor/categories.GENERATED.mjs",
        "vendor/normalizeUrl.GENERATED.mjs"
      ],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

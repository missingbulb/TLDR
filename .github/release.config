# chrome-extension-release config — read by the Claudinite canon reusable
# workflows (the read-release-config action). Only keys that DEVIATE from the
# standard defaults belong here. See the pack RELEASE.md for the full key list.
#
# TLDR is a monorepo: the extension lives under client/, so every path deviates.
# The zip name (tldr.zip) is still derived from the repo name, so it's not here.
# build_env (API_BASE_URL / GOOGLE_CLIENT_ID / EXTENSION_PUBLIC_KEY) stays in the
# workflow stub — it must reference ${{ vars.* }} statically.
#
# ship_paths is the curated set the zip actually contains — kept honest against
# client/scripts/build-zip.mjs's SHIP list by client/test/release-ship-paths.test.mjs.
manifest_path=client/manifest.json
package_json_path=client/package.json
setup_command=
test_command=npm test && npm --prefix client test
ship_paths=client/manifest.json client/config.mjs client/src client/vendor client/icons

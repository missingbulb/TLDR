{
  "name": "tldr-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TLDR Chrome extension (MV3) — side-panel-gated community notes for any web page.",
  "license": "MIT",
  "scripts": {
    "test": "TZ=UTC LANG=C.UTF-8 node --test \"test/**/*.test.mjs\" \"dev/requirements/**/*.test.mjs\"",
    "test:ui": "TZ=UTC LANG=C.UTF-8 node --test \"dev/requirements/**/*.test.mjs\"",
    "refresh:ui": "TZ=UTC LANG=C.UTF-8 node dev/requirements/shared/render/refresh-snapshots.mjs",
    "build": "node scripts/build-zip.mjs"
  },
  "devDependencies": {
    "jsdom": "^29.1.1"
  }
}
